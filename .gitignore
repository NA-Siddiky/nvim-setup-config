.DS_Store
node_modules/
OCI/*.key

# tmux plugin manager (TPM) installs here via the stowed directory symlink
dotfiles/tmux/.config/tmux/plugins/
dotfiles/pi/.pi/*/sessions/*
dotfiles/pi/.pi/*/auth*

# pi copy (never track)
dotfiles/pi copy/

# Broad safety net
**/auth.json
**/.pi/agent/sessions/
**/.pi/agent/stats.db*
**/.pi/agent/run-history.jsonl

# PI stats database
dotfiles/pi/.pi/agent/stats.db-wal
dotfiles/pi/.pi/agent/stats.db-shm
dotfiles/pi/.pi/agent/stats.db

# PI run history
dotfiles/pi/.pi/agent/run-history.jsonl
